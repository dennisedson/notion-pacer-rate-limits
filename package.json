{
  "name": "notion-runner-rate-limits",
  "version": "0.1.0",
  "description": "A registry of common API rate limits and a helper for Notion Worker pacers.",
  "license": "MIT",
  "type": "module",
  "author": "Dennis Edson",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dennisedson/notion-runner-rate-limits.git"
  },
  "bugs": {
    "url": "https://github.com/dennisedson/notion-runner-rate-limits/issues"
  },
  "homepage": "https://github.com/dennisedson/notion-runner-rate-limits#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "validate": "tsx scripts/validate-registry.ts",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "notion",
    "notion-workers",
    "rate-limit",
    "pacer",
    "api"
  ],
  "peerDependencies": {
    "@notionhq/workers": "*"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.5.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.6.0",
    "prettier": "^3.3.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
